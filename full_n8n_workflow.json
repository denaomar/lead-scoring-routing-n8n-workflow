    {
      "parameters": {
        "jsCode": "const rawDomain = $input.first().json.body['Company Website'] || '';\n\n// Strip https://, http://, www. to get clean domain\nconst cleanDomain = rawDomain\n  .replace(/^https?:\\/\\//, '')\n  .replace(/^www\\./, '')\n  .replace(/\\/$/, '');\n\nreturn [{\n  json: {\n    domain: cleanDomain,\n    job_title: $input.first().json.body['Job Title '],\n    raw_domain: rawDomain\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "5e80b07d-fec4-44c8-80b0-d01283083ab5",
      "name": "CleanDomain "
    },
    {
      "parameters": {
        "jsCode": "// Get OpenAI response\nconst rawContent = $input.first().json.choices[0].message.content;\n\n// Parse OpenAI JSON response\nlet parsed;\ntry {\n  parsed = JSON.parse(rawContent);\n} catch (error) {\n  parsed = {\n    fit_score: 0,\n    fit_tier: \"Cold\",\n    fit_reasoning: \"Could not parse scoring response.\",\n    icp_matches: [],\n    icp_gaps: [\"Parsing error\"],\n    suggested_action: \"Disqualify\",\n    personalization_hook: \"\"\n  };\n}\n\n// Get Apollo org data safely\nlet org = {};\ntry {\n  org = $('Apollo Enrichment').first().json.organization || {};\n} catch(e) {\n  org = {};\n}\n\n// Get webhook form data safely  \nlet webhookBody = {};\ntry {\n  webhookBody = $('Webhook').first().json.body || {};\n} catch(e) {\n  webhookBody = {};\n}\n\n// Get clean domain safely\nlet cleanDomain = '';\ntry {\n  cleanDomain = $('CleanDomain').first().json.domain || '';\n} catch(e) {\n  cleanDomain = '';\n}\n\n// Return flat merged object\nreturn [{\n  json: {\n    fit_score: parsed.fit_score,\n    fit_tier: parsed.fit_tier,\n    fit_reasoning: parsed.fit_reasoning,\n    icp_matches: parsed.icp_matches,\n    icp_gaps: parsed.icp_gaps,\n    suggested_action: parsed.suggested_action,\n    personalization_hook: parsed.personalization_hook,\n    company_name: org.name || 'Unknown',\n    industry: org.industry || 'Unknown',\n    employee_count: org.estimated_num_employees || 0,\n    description: org.short_description || '',\n    tech_stack: org.technology_names || [],\n    linkedin: org.linkedin_url || '',\n    primary_domain: org.primary_domain || '',\n    job_title: webhookBody['Job Title '] || 'Unknown',\n    prospect_email: webhookBody['Work Email'] || webhookBody['Email Address'] || '',\n    domain: cleanDomain,\n    processed_at: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

    {
      "parameters": {
        "method": "POST",
        "url": "https://slack.com/api/chat.postMessage",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"channel\": \"{{ $json.slack_user_id }}\",\n  \"text\": \"🔥 New Hot Lead: {{ $json.company_name }} - Score {{ $json.fit_score }}/10\",\n  \"blocks\": [\n    {\n      \"type\": \"header\",\n      \"text\": {\n        \"type\": \"plain_text\",\n        \"text\": \"🔥 HOT LEAD — {{ $json.company_name }} ({{ $json.fit_score }}/10)\"\n      }\n    },\n    {\n      \"type\": \"section\",\n      \"fields\": [\n        { \"type\": \"mrkdwn\", \"text\": \"*Company:*\\n{{ $json.company_name }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Industry:*\\n{{ $json.industry }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Employees:*\\n{{ $json.employee_count }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Job Title:*\\n{{ $json.job_title }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Domain:*\\n{{ $json.primary_domain }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*ICP Score:*\\n{{ $json.fit_score }}/10\" }\n      ]\n    },\n    {\n      \"type\": \"section\",\n      \"text\": { \"type\": \"mrkdwn\", \"text\": \"*Why they fit:*\\n{{ $json.fit_reasoning }}\" }\n    },\n    { \"type\": \"divider\" },\n    {\n      \"type\": \"section\",\n      \"text\": { \"type\": \"mrkdwn\", \"text\": \"📧 *Draft Email Ready*\\n*Subject:* {{ $json.email_subject }}\" }\n    },\n    {\n      \"type\": \"section\",\n      \"text\": { \"type\": \"mrkdwn\", \"text\": \"```{{ $json.email_body }}```\" }\n    },\n    {\n      \"type\": \"actions\",\n      \"elements\": [\n        {\n          \"type\": \"button\",\n          \"text\": { \"type\": \"plain_text\", \"text\": \"✉️ Edit & Send\" },\n          \"style\": \"primary\",\n          \"url\": \"mailto:{{ $json.prospect_email }}?subject={{ $json.email_subject.replace(/ /g, '%20') }}&body={{ $json.email_body.replace(/ /g, '%20').replace(/\\n/g, '%0A') }}\"\n        }\n      ]\n    },\n    {\n      \"type\": \"context\",\n      \"elements\": [\n        { \"type\": \"mrkdwn\", \"text\": \"Processed in under 60 seconds | {{ $json.processed_at }}\" }\n      ]\n    }\n  ]\n}",
        "options": {}
      },

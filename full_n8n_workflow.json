        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"response_format\": { \"type\": \"json_object\" },\n  \"temperature\": 0.7,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a B2B sales rep writing warm follow-up emails to inbound leads who just expressed interest in your product. Write concise, personalized responses that feel human and timely. Return only valid JSON with keys 'subject' and 'body'. No markdown.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify(\"Write a warm follow-up email for an inbound lead who just submitted a demo request form.\\n\\nSENDER CONTEXT: We help B2B revenue teams automate GTM workflows using AI — saving 10+ hours/week on manual prospecting, routing, and reporting.\\n\\nPROSPECT:\\nCompany: \" + $json.company_name + \"\\nIndustry: \" + $json.industry + \"\\nEmployees: \" + $json.employee_count + \"\\nJob Title: \" + $json.job_title + \"\\nTech Stack: \" + $json.tech_stack.join(', ') + \"\\nPersonalization Hook: \" + $json.personalization_hook + \"\\nWhy they are a good fit: \" + $json.fit_reasoning + \"\\n\\nREQUIREMENTS:\\n- Subject: warm, references their company, does not sound like a cold email\\n- Body: 3-4 sentences max\\n- Acknowledge they reached out — they came to us\\n- Reference one specific thing about their company that shows you did your homework\\n- One concrete outcome we deliver relevant to their role and company size\\n- CTA: offer a specific time or ask for their availability this week\\n- Tone: warm, direct, peer-to-peer — they already know who we are\\n\\nReturn as JSON: {\\\"subject\\\": \\\"...\\\", \\\"body\\\": \\\"...\\\"}\") }}\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [

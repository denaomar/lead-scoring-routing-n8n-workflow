      "parameters": {
        "jsCode": "let leadData = {};\ntry {\n  leadData = $('Parse Email Draft').first().json || {};\n} catch(e) {\n  leadData = {};\n}\n\nconst employees = leadData.employee_count || 0;\nconst industry = (leadData.industry || '').toLowerCase();\n\nlet rep_email;\nlet rep_first_name;\nlet routing_reason;\n\nif (employees >= 500) {\n  rep_email = 'diinaelhlaly@gmail.com';\n  rep_first_name = 'Dena';\n  routing_reason = 'enterprise_territory';\n} else if (industry.includes('fintech') || \n           industry.includes('finance')) {\n  rep_email = 'diinaelhlaly@gmail.com';\n  rep_first_name = 'Dena';\n  routing_reason = 'fintech_vertical';\n} else {\n  rep_email = 'your@personalgmail.com';\n  rep_first_name = 'Dena';\n  routing_reason = 'default_routing';\n}\n\nreturn [{\n  json: {\n    ...leadData,\n    rep_email: rep_email,\n    rep_first_name: rep_first_name,\n    routing_reason: routing_reason\n  }\n}];"
      },

    {
      "parameters": {
        "jsCode": "const rawContent = $input.first().json.choices[0].message.content;\n\nlet emailParsed;\ntry {\n  emailParsed = JSON.parse(rawContent);\n} catch(e) {\n  emailParsed = {\n    subject: 'Following up on your demo request',\n    body: 'Could not generate email draft — please follow up manually.'\n  };\n}\n\n// The IF node passed ICP data through unchanged\n// so it has everything from Clean ICP Match Output\nlet icpData = {};\ntry {\n  icpData = $('Hot/Warm Lead?').first().json || {};\n} catch(e) {\n  icpData = {};\n}\n\nreturn [{\n  json: {\n    ...icpData,\n    email_subject: emailParsed.subject,\n    email_body: emailParsed.body,\n    email_drafted: true,\n    workflow_stage: 'email_ready_for_review'\n  }\n}];"
      },

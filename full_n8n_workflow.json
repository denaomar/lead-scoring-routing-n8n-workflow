        "jsCode": "const slackUserId = $input.first().json.user?.id || '';\n\nlet leadData = {};\ntry {\n  leadData = $('Parse Email Draft').first().json || {};\n} catch(e) {\n  leadData = {};\n}\n\nreturn [{\n  json: {\n    ...leadData,\n    slack_user_id: slackUserId\n  }\n}];"
      },
